# ─── Memory Worker — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in the real values.
# .env is gitignored and never committed.

# Claude API
ANTHROPIC_API_KEY=

# Microsoft Azure (same app as CRM worker)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Telegram bot (@DayaProjectBot)
TELEGRAM_MEMORY_BOT_TOKEN=
TELEGRAM_MEMORY_BOT_USERNAME=DayaProjectBot

# Graph webhook validation (any random string — generate with: openssl rand -hex 16)
MEMORY_CLIENT_STATE=

# This worker's public URL (used for Graph webhook registration + self-chain backfill)
MEMORY_WORKER_URL=https://memory.wearedaya.com

# Admin endpoint auth (any random string — protects /backfill, /reset-db, etc.)
INTERNAL_SECRET=

# OneDrive export settings
ONEDRIVE_USER_EMAIL=peterkimani@wearedaya.com
ONEDRIVE_FILE_PATH=Memory Worker/Project Memory.xlsx

# SQLite database path (shared across all 3 workers on VPS)
KV_DB_PATH=/app/kv.sqlite

# HTTP port (default: 3001)
PORT=3001
